{
  "family": "backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::159773920634:role/LabRole",
  "containerDefinitions": [
    {
      "name": "backend-container",
      "image": "159773920634.dkr.ecr.us-east-1.amazonaws.com/backend-innovatech:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ]
    }
  ]
}
